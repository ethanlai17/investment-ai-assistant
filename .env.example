# DeepSeek (Flash for per-ticker insights, Pro for market narrative)
DEEPSEEK_API_KEY=sk-...

# Gmail SMTP — use a Gmail App Password (16 chars), not your account password
# Enable 2FA → Google Account > Security > App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-16-char-app-password
RECIPIENT_EMAIL=your-email@gmail.com

# Ticker list (comma-separated, no spaces)
TICKERS=AAPL,MSFT,GOOGL,AMZN,TSLA

# Data windows
NEWS_LOOKBACK_DAYS=1
PRICE_LOOKBACK_DAYS=500
TRAINING_WINDOW_DAYS=252

# Scheduler
SCHEDULE_HOUR=9
SCHEDULE_MINUTE=30
SCHEDULE_TIMEZONE=Europe/London

# Logging
LOG_LEVEL=INFO

# Models (tiered by complexity)
FLASH_MODEL=deepseek-v3
PRO_MODEL=deepseek-v3

# Directories
OUTPUTS_DIR=outputs
LOGS_DIR=logs
