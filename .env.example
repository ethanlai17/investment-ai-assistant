# Anthropic (Haiku for per-ticker insights, Sonnet for market narrative)
ANTHROPIC_API_KEY=sk-ant-...

# Gmail SMTP — use a Gmail App Password (16 chars), not your account password
# Enable 2FA → Google Account > Security > App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-16-char-app-password
RECIPIENT_EMAIL=your-email@gmail.com

# Ticker list (comma-separated, no spaces)
TICKERS=META,KGC,ORCL,IITU,MU

# Data windows
NEWS_LOOKBACK_DAYS=1
PRICE_LOOKBACK_DAYS=90
TRAINING_WINDOW_DAYS=60

# Scheduler
SCHEDULE_HOUR=9
SCHEDULE_MINUTE=30
SCHEDULE_TIMEZONE=Europe/London

# Logging
LOG_LEVEL=INFO

# Models (tiered by complexity)
HAIKU_MODEL=claude-haiku-4-5-20251001
SONNET_MODEL=claude-sonnet-4-6

# Directories
OUTPUTS_DIR=outputs
LOGS_DIR=logs
